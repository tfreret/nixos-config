{ config, pkgs, lib, ... }:

let
  gitlabToken = "FIX ME";
  gitlabHost = "FIX ME";
in
{
  home-manager.sharedModules = [
    ({ lib, ... }: {
      programs.git.settings = {
        user.name = lib.mkForce "FIX ME";
        user.email = lib.mkForce "FIX ME";

        url = {
          "https://${gitlabHost}/".insteadOf = "git://${gitlabHost}/";
          "https://oauth2:${gitlabToken}@${gitlabHost}/".insteadOf = "https://${gitlabHost}/";
        };
      };

      programs.go.env = {
        GOPRIVATE = gitlabHost;
        GONOSUMDB = gitlabHost;
        GOINSECURE = "${gitlabHost},FIX ME";
      };

      home.sessionVariables = {
        GIT_TERMINAL_PROMPT = "0";
      };

      # Local-only opencode config override (kept out of git)
      xdg.configFile."opencode/opencode.json" = lib.mkForce {
        text = ''
        {
          "$schema": "https://opencode.ai/config.json",
          "permission": {
            "bash": {
              "*": "ask",
              "git *": "allow",
              "git commit *": "deny",
              "git push *": "deny",
              "grep *": "allow"
            }
          },
          "provider": {
            "FIX ME": {
              "npm": "FIX ME",
              "name": "FIX ME",
              "options": {
                "baseURL": "FIX ME",
                "apiKey": "FIX ME"
              },
              "models": {
                "FIX ME": {"name": "FIX ME"}
              }
            }
          }
        }
      '';
      };
    })
  ];

  # networking.hosts = {
  #   "100.100.100.100" = [ "FIX ME" ];
  #   "100.100.100.100" = [ "FIX ME" "FIX ME" ];
  #   "100.100.100.100" = [ "FIX ME" ];
  #   "100.100.100.100" = [ "FIX ME" "FIX ME" ];
  # };

  # environment.variables = {
    # HTTP_PROXY  = "http://fix.me.com:8080";
    # HTTPS_PROXY = "http://fix.me.com:8080";
  # };

  # environment.systemPackages = with pkgs; [
    # azure-cli
    # kubectl
    # awscli2
  # ];

  # programs.bash.shellAliases = {
  #   # work-login = "az login && vpn-connect";
  # };

  # home-manager.users.tfreret = { ... }: {
